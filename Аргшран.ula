    caseListLayout.SortOrder = Enum.SortOrder.Name

    local function refreshCaseList(searchText)
        for _, child in pairs(caseScroll:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        
        for _, caseName in ipairs(AllCases) do
            if searchText == "" or string.find(string.lower(caseName), string.lower(searchText)) then
                local btn = Instance.new("TextButton")
                btn.Parent = caseScroll
                btn.BackgroundColor3 = (caseName == Settings.SelectedCase) and Colors.Secondary or Colors.BgDark
                btn.BorderSizePixel = 0
                btn.Size = UDim2.new(1, -10, 0, 28)
                btn.Font = Enum.Font.Gotham
                btn.Text = caseName
                btn.TextColor3 = (caseName == Settings.SelectedCase) and Colors.Black or Colors.TextLight
                btn.TextSize = 10
                local btnCorner = Instance.new("UICorner")
                btnCorner.CornerRadius = UDim.new(0, 5)
                btnCorner.Parent = btn
                
                btn.MouseButton1Click:Connect(function()
                    Settings.SelectedCase = caseName
                    selectedLabel.Text = "📦 " .. Settings.SelectedCase
                    caseFrame.Visible = false
                    refreshCaseList("")
                end)
            end
        end
    end

    caseSearch:GetPropertyChangedSignal("Text"):Connect(function()
        refreshCaseList(caseSearch.Text)
    end)

    closeCaseBtn.MouseButton1Click:Connect(function()
        caseFrame.Visible = false
    end)

    selectCaseBtn.MouseButton1Click:Connect(function()
        caseFrame.Visible = true
        refreshCaseList("")
    end)

