    -- ========== ФУНКЦІЇ ОНОВЛЕННЯ ПОЗИЦІЙ ==========
    local function updateIconPositions()
        local screenSize = workspace.CurrentCamera.ViewportSize
        local luckPos = UDim2.new(1, -70, 1, -80)
        local savePos = UDim2.new(1, -130, 1, -80)
        
        if LuckActive and SaveActive then
            luckIcon.Position = UDim2.new(1, -70, 1, -80)
            saveIcon.Position = UDim2.new(1, -130, 1, -80)
        elseif LuckActive then
            luckIcon.Position = UDim2.new(1, -70, 1, -80)
        elseif SaveActive then
            saveIcon.Position = UDim2.new(1, -70, 1, -80)
        end
    end

    local function updateLuckTimer()
        if LuckActive then
            local remaining = LuckEndTime - os.time()
            if remaining <= 0 then
                LuckActive = false
                luckIcon.Visible = false
                luckIndicator.Text = "🍀 УДАЧА: НЕТ"
                luckIndicator.TextColor3 = Colors.TextLight
                updateIconPositions()
            else
                local minutes = math.floor(remaining / 60)
                local seconds = remaining % 60
                luckIconTimerLabel.Text = string.format("%d:%02d", minutes, seconds)
                luckIndicator.Text = "🍀 УДАЧА: " .. string.format("%d:%02d", minutes, seconds)
                luckIndicator.TextColor3 = Colors.Secondary
            end
        end
    end

    local function updateSaveTimer()
        if SaveActive then
            local remaining = SaveEndTime - os.time()
            if remaining <= 0 then
                SaveActive = false
                saveIcon.Visible = false
                saveIndicator.Text = "💾 СЕЙВ: НЕТ"
                saveIndicator.TextColor3 = Colors.TextLight
                updateIconPositions()
            else
                local minutes = math.floor(remaining / 60)
                local seconds = remaining % 60
                saveIconTimerLabel.Text = string.format("%d:%02d", minutes, seconds)
                saveIndicator.Text = "💾 СЕЙВ: " .. string.format("%d:%02d", minutes, seconds)
                saveIndicator.TextColor3 = Colors.Secondary
            end
        end
    end

    local function updateUI()
        buyBtn.Text = Settings.AutoBuy and "🛍️ ПОКУПКА: ВКЛ" or "🛍️ ПОКУПКА: ВЫКЛ"
        buyBtn.TextColor3 = Settings.AutoBuy and Colors.Secondary or Colors.Red
        
        sellBtn.Text = Settings.AutoSell and "🛒 ПРОДАЖА: ВКЛ" or "🛒 ПРОДАЖА: ВЫКЛ"
        sellBtn.TextColor3 = Settings.AutoSell and Colors.Secondary or Colors.Red
    end

    local function farmLoop()
        while Farming do
            pcall(function()
                local events = ReplicatedStorage:FindFirstChild("Events")
                if events then
                    local openCase = events:FindFirstChild("OpenCase")
                    if openCase then
                        openCase:InvokeServer(Settings.SelectedCase, Settings.OpenAmount)
                    end
                    
                    if Settings.AutoSell then
                        local inventory = events:FindFirstChild("Inventory")
                        if inventory then
                            inventory:FireServer("Sell", "ALL")
                        end
                    end
                    
                    if Settings.AutoBuy then
                        local buyCase = events:FindFirstChild("BuyCase")
                        if buyCase then
                            buyCase:InvokeServer(Settings.SelectedCase, 1)
                        end
                    end
                end
            end)
            task.wait(Settings.FarmDelay)
        end
    end

