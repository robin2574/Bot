    end)

    closeSaveBtn.MouseButton1Click:Connect(function()
        saveFrame.Visible = false
    end)

    startBtn.MouseButton1Click:Connect(function()
        if not Farming then
            Farming = true
            startBtn.Text = "⏹ СТОП ФАРМ"
            statusLabel.Text = "⚡ ФАРМ АКТИВЕН"
            statusLabel.TextColor3 = Colors.Secondary
            FarmThread = task.spawn(farmLoop)
        else
            Farming = false
            if FarmThread then task.cancel(FarmThread) end
            startBtn.Text = "▶ СТАРТ ФАРМ"
            statusLabel.Text = "⚡ СТОП"
            statusLabel.TextColor3 = Colors.TextLight
        end
    end)

    amountBox.FocusLost:Connect(function()
        local num = tonumber(amountBox.Text)
        if num and num >= 1 and num <= 10 then
            Settings.OpenAmount = math.floor(num)
            amountBox.Text = tostring(Settings.OpenAmount)
        else
            amountBox.Text = tostring(Settings.OpenAmount)
        end
    end)

    delayBox.FocusLost:Connect(function()
        local num = tonumber(delayBox.Text)
        if num and num >= 0.001 then
            Settings.FarmDelay = num
            delayBox.Text = tostring(Settings.FarmDelay)
        else
            delayBox.Text = tostring(Settings.FarmDelay)
        end
    end)

    luckTimeBox.FocusLost:Connect(function()
        local num = tonumber(luckTimeBox.Text)
        if num and num >= 1 and num <= 60 then
            Settings.LuckTime = math.floor(num)
            luckTimeBox.Text = tostring(Settings.LuckTime)
        else
            luckTimeBox.Text = tostring(Settings.LuckTime)
        end
    end)

    saveTimeBox.FocusLost:Connect(function()
        local num = tonumber(saveTimeBox.Text)
        if num and num >= 1 and num <= 60 then
            Settings.SaveTime = math.floor(num)
            saveTimeBox.Text = tostring(Settings.SaveTime)
        else
            saveTimeBox.Text = tostring(Settings.SaveTime)
        end
    end)

    startLuckActBtn.MouseButton1Click:Connect(function()
        local timeMin = tonumber(luckTimeBox.Text) or 5
        if timeMin < 1 then timeMin = 1 end
        if timeMin > 60 then timeMin = 60 end
        
        LuckActive = true
        LuckEndTime = os.time() + (timeMin * 60)
        luckIcon.Visible = true
        luckIconMultLabel.Text = "x" .. Settings.LuckMultiplier
        luckFrame.Visible = false
        updateIconPositions()
    end)

    startSaveActBtn.MouseButton1Click:Connect(function()
        local timeMin = tonumber(saveTimeBox.Text) or 5
        if timeMin < 1 then timeMin = 1 end
        if timeMin > 60 then timeMin = 60 end
        
        SaveActive = true
        SaveEndTime = os.time() + (timeMin * 60)
        saveIcon.Visible = true
        saveFrame.Visible = false
        updateIconPositions()
    end)

    luckIconCloseBtn.MouseButton1Click:Connect(function()
        LuckActive = false
        luckIcon.Visible = false
        luckIndicator.Text = "🍀 УДАЧА: НЕТ"
        luckIndicator.TextColor3 = Colors.TextLight
        updateIconPositions()
    end)

    saveIconCloseBtn.MouseButton1Click:Connect(function()
        SaveActive = false
        saveIcon.Visible = false
        saveIndicator.Text = "💾 СЕЙВ: НЕТ"
        saveIndicator.TextColor3 = Colors.TextLight
        updateIconPositions()
    end)

    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            multList.Visible = false
        end
    end)

    RunService.Heartbeat:Connect(function()
        updateLuckTimer()
        updateSaveTimer()
    end)

    -- ========== ІНІЦІАЛІЗАЦІЯ ==========
    updateUI()
    amountBox.Text = tostring(Settings.OpenAmount)
    delayBox.Text = tostring(Settings.FarmDelay)
    luckTimeBox.Text = tostring(Settings.LuckTime)
    saveTimeBox.Text = tostring(Settings.SaveTime)
    multBtn.Text = "x" .. Settings.LuckMultiplier
    selectedLabel.Text = "📦 " .. Settings.SelectedCase

    print("✅ NEO CASE FARM V12 LOADED!")
    print("📦 Фіолетовий дизайн | Пароль: mr.comcom")
    print("🍀 УДАЧА і 💾 СЕЙВ - окремі меню в налаштуваннях")
end
