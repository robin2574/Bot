-- ========== ФУНКЦИИ ==========
local function updateLuckTimer()
    if LuckActive then
        local remaining = LuckEndTime - os.time()
        if remaining <= 0 then
            LuckActive = false
            luckIcon.Visible = false
            luckIndicator.Text = "🍀 НЕТ"
            luckIndicator.TextColor3 = Colors.TextLight
        else
            local minutes = math.floor(remaining / 60)
            local seconds = remaining % 60
            luckIconTimer.Text = string.format("%d:%02d", minutes, seconds)
            luckIndicator.Text = "🍀 " .. string.format("%d:%02d", minutes, seconds)
            luckIndicator.TextColor3 = Colors.NeonGreen
        end
    end
end

local function updateSaveTimer()
    if SaveActive then
        local remaining = SaveEndTime - os.time()
        if remaining <= 0 then
            SaveActive = false
            saveIcon.Visible = false
            saveIndicator.Text = "💾 НЕТ"
            saveIndicator.TextColor3 = Colors.TextLight
        else
            local minutes = math.floor(remaining / 60)
            local seconds = remaining % 60
            saveIconTimer.Text = string.format("%d:%02d", minutes, seconds)
            saveIndicator.Text = "💾 " .. string.format("%d:%02d", minutes, seconds)
            saveIndicator.TextColor3 = Colors.NeonGreen
        end
    end
end

local function updateUI()
    buyBtn.Text = Settings.AutoBuy and "🛍️ ВКЛ" or "🛍️ ПОКУПКА: ВЫКЛ"
    buyBtn.TextColor3 = Settings.AutoBuy and Colors.NeonGreen or Colors.Red
    
    sellBtn.Text = Settings.AutoSell and "🛒 ВКЛ" or "🛒 ПРОДАЖА: ВЫКЛ"
    sellBtn.TextColor3 = Settings.AutoSell and Colors.NeonGreen or Colors.Red
end

local function farmLoop()
    while Farming do
        pcall(function()
            local events = ReplicatedStorage:FindFirstChild("Events")
            if events then
                local openCase = events:FindFirstChild("OpenCase")
                if openCase then
                    openCase:InvokeServer(Settings.SelectedCase, Settings.OpenAmount)
                end
                
                if Settings.AutoSell then
                    local inventory = events:FindFirstChild("Inventory")
                    if inventory then
                        inventory:FireServer("Sell", "ALL")
                    end
                end
                
                if Settings.AutoBuy then
                    local buyCase = events:FindFirstChild("BuyCase")
                    if buyCase then
                        buyCase:InvokeServer(Settings.SelectedCase, 1)
                    end
                end
            end
        end)
        task.wait(Settings.FarmDelay)
    end
end

-- ========== СОБЫТИЯ ==========
miniButton.MouseButton1Click:Connect(function()
    mainFrame.Visible = true
    miniFrame.Visible = false
end)

minimizeBtn.MouseButton1Click:Connect(function()
    mainFrame.Visible = false
    miniFrame.Visible = true
end)

buyBtn.MouseButton1Click:Connect(function()
    Settings.AutoBuy = not Settings.AutoBuy
    updateUI()
end)

sellBtn.MouseButton1Click:Connect(function()
    Settings.AutoSell = not Settings.AutoSell
    updateUI()
end)

settingsBtn.MouseButton1Click:Connect(function()
    settingsFrame.Visible = true
end)

closeSettings.MouseButton1Click:Connect(function()
    settingsFrame.Visible = false
end)

startBtn.MouseButton1Click:Connect(function()
    if not Farming then
        Farming = true
        startBtn.Text = "⏹ СТОП"
        statusLabel.Text = "⚡ ФАРМ"
        statusLabel.TextColor3 = Colors.NeonGreen
        task.spawn(farmLoop)
    else
        Farming = false
        startBtn.Text = "▶ СТАРТ"
        statusLabel.Text = "⚡ СТОП"
        statusLabel.TextColor3 = Colors.TextLight
    end
end)

amountBox.FocusLost:Connect(function()
    local num = tonumber(amountBox.Text)
    if num and num >= 1 and num <= 100 then
        Settings.OpenAmount = math.floor(num)
        amountBox.Text = tostring(Settings.OpenAmount)
    else
        amountBox.Text = tostring(Settings.OpenAmount)
    end
end)

delayBox.FocusLost:Connect(function()
    local num = tonumber(delayBox.Text)
    if num and num >= 0.001 then
        Settings.FarmDelay = num
        delayBox.Text = tostring(Settings.FarmDelay)
    else
        delayBox.Text = tostring(Settings.FarmDelay)
    end
end)

luckTimeBox.FocusLost:Connect(function()
    local num = tonumber(luckTimeBox.Text)
    if num and num >= 1 and num <= 60 then
        Settings.LuckTime = math.floor(num)
        luckTimeBox.Text = tostring(Settings.LuckTime)
    else
        luckTimeBox.Text = tostring(Settings.LuckTime)
    end
end)

saveTimeBox.FocusLost:Connect(function()
    local num = tonumber(saveTimeBox.Text)
    if num and num >= 1 and num <= 60 then
        Settings.SaveTime = math.floor(num)
        saveTimeBox.Text = tostring(Settings.SaveTime)
    else
        saveTimeBox.Text = tostring(Settings.SaveTime)
    end
end)

startLuckBtn.MouseButton1Click:Connect(function()
    local timeMin = tonumber(luckTimeBox.Text) or 5
    if timeMin < 1 then timeMin = 1 end
    if timeMin > 60 then timeMin = 60 end
    
    LuckActive = true
    LuckEndTime = os.time() + (timeMin * 60)
    luckIcon.Visible = true
    luckIconMult.Text = "x" .. Settings.LuckMultiplier
    settingsFrame.Visible = false
end)

startSaveBtn.MouseButton1Click:Connect(function()
    local timeMin = tonumber(saveTimeBox.Text) or 5
    if timeMin < 1 then timeMin = 1 end
    if timeMin > 60 then timeMin = 60 end
    
    SaveActive = true
    SaveEndTime = os.time() + (timeMin * 60)
    saveIcon.Visible = true
    settingsFrame.Visible = false
end)

luckIconClose.MouseButton1Click:Connect(function()
    LuckActive = false
    luckIcon.Visible = false
    luckIndicator.Text = "🍀 НЕТ"
    luckIndicator.TextColor3 = Colors.TextLight
end)

saveIconClose.MouseButton1Click:Connect(function()
    SaveActive = false
    saveIcon.Visible = false
    saveIndicator.Text = "💾 НЕТ"
    saveIndicator.TextColor3 = Colors.TextLight
end)

UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        luckMultList.Visible = false
    end
end)

RunService.Heartbeat:Connect(function()
    updateLuckTimer()
    updateSaveTimer()
end)

-- ========== ЗАПУСК ==========
refreshCaseList()
updateUI()
amountBox.Text = tostring(Settings.OpenAmount)
delayBox.Text = tostring(Settings.FarmDelay)
luckTimeBox.Text = tostring(Settings.LuckTime)
saveTimeBox.Text = tostring(Settings.SaveTime)
luckMultBtn.Text = "x" .. Settings.LuckMultiplier

