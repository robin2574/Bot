local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")

-- ВСЕ КЕЙСЫ
local DefaultCases = {
    "Trash", "Daily", "Photon Core", "Divine", "Beggar", "Plodder",
    "Office Clerk", "Manager", "Director", "Oligarch", "Frozen Heart",
    "Bubble Gum", "Cats", "Glitch", "Dream", "Bloody Night", "Heavenfall",
    "M5 F90", "G63", "Porsche 911", "URUS", "Gold", "Dark", "Palm",
    "Burj", "Luxury", "Marina", "Cursed Demon"
}

local CustomCases = {}
local AllCases = {}

local function updateAllCases()
    AllCases = {}
    for _, v in ipairs(DefaultCases) do table.insert(AllCases, v) end
    for _, v in ipairs(CustomCases) do table.insert(AllCases, v) end
end
updateAllCases()

-- ЦВЕТА
