    OpenAmount = 10,
    FarmDelay = 0.01,
    LuckMultiplier = 2,
    LuckTime = 5,
    SaveTime = 5,
}

-- ЗАГРУЗКА
local function loadCustomCases()
    pcall(function()
        if readfile and isfile and isfile("NeoCaseFarm_Custom.json") then
            local data = HttpService:JSONDecode(readfile("NeoCaseFarm_Custom.json"))
            CustomCases = data or {}
            updateAllCases()
        end
    end)
end

local function saveCustomCases()
    pcall(function()
        if writefile then
            writefile("NeoCaseFarm_Custom.json", HttpService:JSONEncode(CustomCases))
        end
    end)
end
loadCustomCases()

