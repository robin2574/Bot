-- ========== ОБНОВЛЕНИЕ СПИСКА ==========
local function refreshCaseList()
    for _, child in pairs(caseScrollFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    for _, caseName in ipairs(AllCases) do
        local isCustom = false
        for _, v in ipairs(CustomCases) do
            if v == caseName then isCustom = true break end
        end
        
        local btn = Instance.new("TextButton")
        btn.Parent = caseScrollFrame
        btn.BackgroundColor3 = (caseName == Settings.SelectedCase) and Colors.NeonGreen or Colors.BgDark
        btn.BorderSizePixel = 0
        btn.Size = UDim2.new(1, -10, 0, 24)
        btn.Font = Enum.Font.Gotham
        btn.Text = caseName .. (isCustom and " ✨" or "")
        btn.TextColor3 = (caseName == Settings.SelectedCase) and Colors.Black or Colors.NeonGreen
        btn.TextSize = 9
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 4)
        btnCorner.Parent = btn
        
        btn.MouseButton1Click:Connect(function()
            Settings.SelectedCase = caseName
            refreshCaseList()
        end)
    end
end

-- ДОБАВЛЕНИЕ КЕЙСА
addCaseBtn.MouseButton1Click:Connect(function()
    local newCase = addCaseBox.Text
    if newCase ~= "" then
        local exists = false
        for _, v in ipairs(AllCases) do
            if v == newCase then exists = true break end
        end
        if not exists then
            table.insert(CustomCases, newCase)
            updateAllCases()
            saveCustomCases()
            refreshCaseList()
            addCaseBox.Text = ""
            addCaseBtn.Text = "✅"
            task.wait(0.5)
            addCaseBtn.Text = "➕"
        else
            addCaseBtn.Text = "❌"
            task.wait(0.5)
            addCaseBtn.Text = "➕"
        end
    end
end)

