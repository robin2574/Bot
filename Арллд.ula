-- ========== ФУНКЦИИ ==========
local function UpdateSelectedInfo()
    local count = #SelectedCases
    if count == 0 then
        SelectedInfo.Text = "⚠ НЕ ВЫБРАНО НИ ОДНОГО КЕЙСА! (0/10)"
        SelectedInfo.TextColor3 = Color3.fromRGB(255, 100, 100)
    else
        local names = {}
        for i = 1, math.min(3, count) do
            table.insert(names, SelectedCases[i])
        end
        local text = "📦 ВЫБРАНО: " .. table.concat(names, ", ")
        if count > 3 then
            text = text .. " +" .. (count - 3) .. " ещё"
        end
        SelectedInfo.Text = text .. " (" .. count .. "/10)"
        SelectedInfo.TextColor3 = Color3.fromRGB(100, 150, 255)
    end
end

local function RefreshCaseList()
    for _, child in pairs(ScrollFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    for i, caseName in ipairs(BattleCases) do
        local btn = Instance.new("TextButton")
        btn.Parent = ScrollFrame
        btn.BackgroundColor3 = Color3.fromRGB(35, 40, 55)
        btn.BorderColor3 = Color3.fromRGB(100, 150, 255)
        btn.BorderSizePixel = 1
        btn.Size = UDim2.new(1, 0, 0, 30)
        btn.Font = Enum.Font.Gotham
        btn.Text = caseName
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 10
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 4)
        btnCorner.Parent = btn

        -- Проверка, выбран ли кейс
        local isSelected = false
        for _, selected in ipairs(SelectedCases) do
            if selected == caseName then
                isSelected = true
                break
            end
        end
        
        if isSelected then
            btn.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
            btn.TextColor3 = Color3.fromRGB(0, 0, 0)
        end

        btn.MouseButton1Click:Connect(function()
            local found = false
            local index = nil
            for i, selected in ipairs(SelectedCases) do
                if selected == caseName then
                    found = true
                    index = i
                    break
                end
            end
            
            if found then
                table.remove(SelectedCases, index)
            else
                if #SelectedCases < 10 then
                    table.insert(SelectedCases, caseName)
                else
                    StatusLabel.Text = "⚠ МАКСИМУМ 10 КЕЙСОВ!"
                    StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
                    task.wait(1)
                    StatusLabel.Text = "⚡ ГОТОВ"
                    StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
                    return
                end
            end
            UpdateSelectedInfo()
            RefreshCaseList()
        end)
    end

    local count = #ScrollFrame:GetChildren() - 2
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, count * 34 + 10)
end

local function UpdateClaimUI()
    if AutoClaim then
        ClaimBtn.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
        ClaimBtn.BorderColor3 = Color3.fromRGB(150, 200, 255)
        ClaimBtn.Text = "🟢 АВТОЗАБОР: ВКЛ"
        ClaimBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
    else
        ClaimBtn.BackgroundColor3 = Color3.fromRGB(40, 35, 50)
        ClaimBtn.BorderColor3 = Color3.fromRGB(255, 100, 100)
        ClaimBtn.Text = "🔴 АВТОЗАБОР: ВЫКЛ"
        ClaimBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end

ClaimBtn.MouseButton1Click:Connect(function()
    AutoClaim = not AutoClaim
    UpdateClaimUI()
end)

SettingsBtn.MouseButton1Click:Connect(function()
    SettingsFrame.Visible = true
    SettingsFrame.Position = MainFrame.Position
end)

InfoBtn.MouseButton1Click:Connect(function()
    InfoFrame.Visible = true
    InfoFrame.Position = MainFrame.Position
end)

SaveSettingsBtn.MouseButton1Click:Connect(function()
    local num = tonumber(BattleCountBox.Text)
    if num and num >= 1 and num <= 50 then
        BattleAmount = math.floor(num)
        BattleCountBox.Text = tostring(BattleAmount)
    else
        BattleAmount = 1
        BattleCountBox.Text = "1"
    end
    
    local num2 = tonumber(DelayBox.Text)
    if num2 and num2 >= 0.5 then
        FarmDelay = num2
        DelayBox.Text = tostring(FarmDelay)
    else
        FarmDelay = 1
        DelayBox.Text = "1"
    end
    
    SettingsFrame.Visible = false
end)

BattleCountBox.FocusLost:Connect(function()
    local num = tonumber(BattleCountBox.Text)
    if num and num >= 1 and num <= 50 then
        BattleAmount = math.floor(num)
        BattleCountBox.Text = tostring(BattleAmount)
    else
        BattleAmount = 1
        BattleCountBox.Text = "1"
    end
end)

DelayBox.FocusLost:Connect(function()
    local num = tonumber(DelayBox.Text)
    if num and num >= 0.5 then
        FarmDelay = num
        DelayBox.Text = tostring(FarmDelay)
    else
        FarmDelay = 1
        DelayBox.Text = "1"
    end
end)

-- ========== ПОИСК СОБЫТИЙ ==========
local function FindEvent(eventNames)
    local Events = ReplicatedStorage:FindFirstChild("Events")
    if not Events then
        -- Поиск в других возможных местах
        for _, container in pairs(ReplicatedStorage:GetChildren()) do
            if container:IsA("Folder") or container:IsA("ModuleScript") then
                Events = container
                break
            end
        end
    end
    
    for _, name in ipairs(eventNames) do
        if Events then
            local event = Events:FindFirstChild(name)
            if event then
                return event, name
            end
        end
        -- Поиск в ReplicatedStorage напрямую
        local event = ReplicatedStorage:FindFirstChild(name)
        if event then
            return event, name
        end
    end
    return nil, nil
end

-- ========== ОСНОВНОЙ ЦИКЛ БИТВ ==========
local function CreateBattle(caseName)
    pcall(function()
        -- Пробуем разные возможные названия событий для создания битвы
        local createEvents = {"CreateBattle", "StartBattle", "BattleCreate", "Create", "Battle_Start"}
        local createEvent, foundName = FindEvent(createEvents)
        
        if createEvent then
            if createEvent:IsA("RemoteFunction") then
                createEvent:InvokeServer(caseName)
            elseif createEvent:IsA("RemoteEvent") then
                createEvent:FireServer(caseName)
            end
            StatusLabel.Text = "⚔️ Создаю битву с кейсом: " .. caseName
            return true
        end
        return false
    end)
    return false
end

local function SelectCase(caseName)
