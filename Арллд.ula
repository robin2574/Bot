-- ========== ОСНОВНОЙ ЦИКЛ ФАРМА БИТВ ==========
local function BattleLoop()
    while Farming do
        for _, caseName in ipairs(SelectedCases) do
            if not Farming then break end
            
            pcall(function()
                StatusLabel.Text = "⚔️ Обработка кейса: " .. caseName
                
                -- 1. Создать битву
                CreateBattle(caseName)
                task.wait(0.5)
                
                -- 2. Выбрать кейс
                SelectCase(caseName)
                task.wait(0.3)
                
                -- 3. Нажать + (если нужно добавить)
                AddCase(caseName)
                task.wait(0.3)
                
                -- 4. Подтвердить создание
                ConfirmCreate()
                task.wait(0.5)
                
                -- 5. Играть с ботом
                PlayWithBot()
                task.wait(1)
                
                -- 6. Забрать награду (если включено)
                if AutoClaim then
                    ClaimReward()
                    task.wait(0.3)
                end
                
                -- 7. Закрыть окно битвы
                CloseBattle()
                task.wait(0.3)
                
                StatusLabel.Text = "✅ Битва завершена: " .. caseName
            end)
            
            task.wait(FarmDelay)
        end
        
        -- Пауза между полными циклами всех кейсов
        task.wait(1)
    end
end

StartBtn.MouseButton1Click:Connect(function()
    if not Farming then
        if #SelectedCases == 0 then
            StatusLabel.Text = "⚠ ВЫБЕРИТЕ КЕЙСЫ ДЛЯ БИТВ!"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            task.wait(1.5)
            StatusLabel.Text = "⚡ ГОТОВ"
            StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
            return
        end
        
        Farming = true
        StartBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 50)
        StartBtn.Text = "⏹ СТОП"
        StatusLabel.Text = "⚔️ ФАРМ БИТВ АКТИВЕН"
        StatusLabel.TextColor3 = Color3.fromRGB(100, 150, 255)
        task.spawn(BattleLoop)
    else
        Farming = false
        StartBtn.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
        StartBtn.Text = "▶ ФАРМ БИТВ"
        StatusLabel.Text = "⚡ СТОП"
        StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    end
end)

-- ========== ВЫВОД ВСЕХ СОБЫТИЙ В КОНСОЛЬ ==========
local function DebugEvents()
    print("========== ПОИСК СОБЫТИЙ ==========")
    local function scanContainer(container, path)
        for _, child in pairs(container:GetChildren()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                print(path .. child.Name)
            elseif child:IsA("Folder") or child:IsA("ModuleScript") then
                scanContainer(child, path .. child.Name .. "/")
            end
        end
    end
    scanContainer(ReplicatedStorage, "ReplicatedStorage/")
    print("====================================")
end

