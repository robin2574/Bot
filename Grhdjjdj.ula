-- Анимация искр
task.spawn(function()
    while true do
        if LuckActive then
            Spark1.Visible = not Spark1.Visible
            Spark2.Visible = not Spark2.Visible
        else
            Spark1.Visible = true
            Spark2.Visible = true
        end
        task.wait(0.5)
    end
end)

