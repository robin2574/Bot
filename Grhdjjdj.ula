end

FuncScroll.CanvasSize = UDim2.new(0, 0, 0, #functions * 30)

-- ========== ФУНКЦИЯ ОБНОВЛЕНИЯ СПИСКА КЕЙСОВ ==========
local function RefreshCaseList()
    for _, child in pairs(ScrollFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    for i, data in ipairs(CasesDatabase) do
        local caseName = data.Name
        local casePrice = data.Price
        local isSelected = false
        for _, s in pairs(SelectedCases) do
            if s == caseName then isSelected = true break end
        end
        
        local btn = Instance.new("TextButton")
        btn.Parent = ScrollFrame
        btn.BackgroundColor3 = isSelected and Color3.fromRGB(100, 200, 50) or Color3.fromRGB(35, 40, 25)
        btn.BorderColor3 = Color3.fromRGB(150, 255, 100)
        btn.BorderSizePixel = 1
        btn.Size = UDim2.new(1, 0, 0, 26)
        btn.Font = Enum.Font.Gotham
        btn.Text = "  " .. caseName
        btn.TextColor3 = isSelected and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(255, 255, 255)
        btn.TextSize = 10
        btn.TextXAlignment = Enum.TextXAlignment.Left
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 4)
        btnCorner.Parent = btn
        
        -- Цена с множителем
        local priceLabel = Instance.new("TextLabel")
        priceLabel.Parent = btn
        priceLabel.Size = UDim2.new(0, 90, 1, 0)
        priceLabel.Position = UDim2.new(1, -95, 0, 0)
        priceLabel.BackgroundTransparency = 1
        priceLabel.Font = Enum.Font.GothamBold
        priceLabel.Text = formatPrice(casePrice, OpenAmount)
        priceLabel.TextColor3 = casePrice == 0 and Color3.fromRGB(0, 220, 100) or (isSelected and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(150, 255, 100))
        priceLabel.TextSize = 9
        priceLabel.TextXAlignment = Enum.TextXAlignment.Right

        btn.MouseButton1Click:Connect(function()
            local found = false
            for i, s in pairs(SelectedCases) do
                if s == caseName then
                    table.remove(SelectedCases, i)
                    found = true
                    break
                end
            end
            if not found then
                table.insert(SelectedCases, caseName)
            end
            SelectedLabel.Text = "🎯 Выбрано: " .. #SelectedCases .. " кейсов"
            RefreshCaseList()
        end)
    end

    local count = #ScrollFrame:GetChildren() - 2
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, count * 30 + 10)
end

-- АВТОПРОДАЖА
local function UpdateSellUI()
    if AutoSell then
        SellBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 50)
        SellBtn.BorderColor3 = Color3.fromRGB(150, 255, 100)
        SellBtn.Text = "🟢 ПРОД"
        SellBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
    else
        SellBtn.BackgroundColor3 = Color3.fromRGB(40, 35, 40)
        SellBtn.BorderColor3 = Color3.fromRGB(255, 80, 80)
        SellBtn.Text = "🔴 ПРОД"
        SellBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
    end
end

SellBtn.MouseButton1Click:Connect(function()
    AutoSell = not AutoSell
    UpdateSellUI()
end)

SettingsBtn.MouseButton1Click:Connect(function()
    SettingsFrame.Visible = true
    SettingsFrame.Position = MainFrame.Position
end)

InfoBtn.MouseButton1Click:Connect(function()
    InfoFrame.Visible = true
    InfoFrame.Position = MainFrame.Position
end)

AmountBox.FocusLost:Connect(function()
    local num = tonumber(AmountBox.Text)
    if num and num >= 1 and num <= 10 then
        OpenAmount = math.floor(num)
        AmountBox.Text = tostring(OpenAmount)
    else
        OpenAmount = 1
        AmountBox.Text = "1"
    end
    RefreshCaseList()
end)

DelayBox.FocusLost:Connect(function()
    local num = tonumber(DelayBox.Text)
    if num and num >= 0.005 then
        FarmDelay = num
        DelayBox.Text = tostring(FarmDelay)
    else
        FarmDelay = 0.01
        DelayBox.Text = "0.01"
    end
end)

-- ОБНОВЛЕНИЕ ТАЙМЕРА УДАЧИ
local function UpdateLuckTimer()
    if LuckActive then
        local remaining = LuckEndTime - os.time()
        if remaining <= 0 then
            LuckActive = false
            LuckIcon.Visible = false
        else
            local minutes = math.floor(remaining / 60)
            local seconds = remaining % 60
            LuckTimer.Text = string.format("%d:%02d", minutes, seconds)
        end
    end
end

-- ЗАПУСК УДАЧИ
StartLuckSetBtn.MouseButton1Click:Connect(function()
    local timeMin = tonumber(TimeBox.Text) or 5
    if timeMin < 1 then timeMin = 1 end
    if timeMin > 60 then timeMin = 60 end
    
    local multText = MultValue.Text
    local mult = tonumber(multText:gsub("x", "")) or 2
    
    LuckMultiplier = mult
    LuckTime = timeMin
    LuckActive = true
    LuckEndTime = os.time() + (timeMin * 60)
    LuckIcon.Visible = true
    LuckMultLabel.Text = "x" .. LuckMultiplier
    LuckTimer.Text = string.format("%d:00", timeMin)
    LuckSettingsFrame.Visible = false
    SettingsFrame.Visible = false
end)

-- ЗАКРЫТИЕ ИКОНКИ УДАЧИ (клик по ней выключает)
LuckIcon.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        LuckActive = false
        LuckIcon.Visible = false
    end
end)

-- ВЫБОР МНОЖИТЕЛЯ
local multOptions = {"x2", "x4", "x6"}
local multIndex = 1
MultValue.MouseButton1Click:Connect(function()
    multIndex = multIndex % #multOptions + 1
    MultValue.Text = multOptions[multIndex]
end)

-- ОТКРЫТИЕ МЕНЮ УДАЧИ
LuckBtn.MouseButton1Click:Connect(function()
    LuckSettingsFrame.Visible = true
    TimeBox.Text = tostring(LuckTime)
    MultValue.Text = "x" .. LuckMultiplier
end)

-- ФАРМ ЛУП (для нескольких кейсов)
local function FarmLoop()
    while Farming do
        pcall(function()
            local Events = ReplicatedStorage:FindFirstChild("Events")
            if Events then
                local OpenCase = Events:FindFirstChild("OpenCase")
                if OpenCase then
                    for _, caseName in pairs(SelectedCases) do
                        if OpenCase:IsA("RemoteFunction") then
                            OpenCase:InvokeServer(caseName, OpenAmount)
                        else
                            OpenCase:FireServer(caseName, OpenAmount)
                        end
                        task.wait(0.1)
                    end
                end
                if AutoSell then
                    local Inventory = Events:FindFirstChild("Inventory")
                    if Inventory then
                        Inventory:FireServer("Sell", "ALL")
                    end
                end
            end
        end)
        task.wait(FarmDelay)
    end
end

StartBtn.MouseButton1Click:Connect(function()
    if not Farming then
        if #SelectedCases == 0 then
            StatusLabel.Text = "❌ ВЫБЕРИТЕ КЕЙСЫ"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
            task.wait(1)
            StatusLabel.Text = "⚡ СТОП"
            StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
            return
        end
        Farming = true
        StartBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 50)
        StartBtn.Text = "⏹ СТОП"
        StatusLabel.Text = "⚡ ФАРМ"
        StatusLabel.TextColor3 = Color3.fromRGB(150, 255, 100)
        task.spawn(FarmLoop)
    else
        Farming = false
        StartBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 50)
        StartBtn.Text = "▶ ФАРМ"
        StatusLabel.Text = "⚡ СТОП"
        StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    end
end)

-- ЗАПУСК
RefreshCaseList()
UpdateSellUI()
AmountBox.Text = tostring(OpenAmount)
DelayBox.Text = tostring(FarmDelay)
TimeBox.Text = tostring(LuckTime)
MultValue.Text = "x" .. LuckMultiplier

print("✅ ДРОЧИЛЬНЯ ROBINA - TON CASE FARM LOADED!")
print("📦 Многокейс режим активен! Выбирай несколько кейсов!")
