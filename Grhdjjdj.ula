local functions = {
    "📦 МНОГОКЕЙС - можно выбрать несколько кейсов сразу",
    "💰 ЦЕНА МЕНЯЕТСЯ от количества выбранных кейсов (1-10)",
    "🔴 АВТОПРОДАЖА - автоматически продаёт все предметы",
    "🍀 УДАЧА (x2/x4/x6) - множитель на время",
    "⚡ НАСТРОЙКА ЗАДЕРЖКИ - скорость открытия",
    "🎯 ВЫБОР ЛЮБЫХ КЕЙСОВ из списка",
    "💀 АВАТАР И НИК в нижней панели",
    "🧴 НОВАЯ ИКОНКА УДАЧИ (фиолетовая бутылочка)"
}

for _, func in pairs(functions) do
    local lbl = Instance.new("TextLabel")
    lbl.Parent = FuncScroll
    lbl.Size = UDim2.new(1, -10, 0, 20)
    lbl.Text = func
    lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.Gotham
