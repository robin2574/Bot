-- ==================================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local Lighting = game:GetService("Lighting")
local SoundService = game:GetService("SoundService")
local HttpService = game:GetService("HttpService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local MarketplaceService = game:GetService("MarketplaceService")
local StarterGui = game:GetService("StarterGui")
local StarterPlayer = game:GetService("StarterPlayer")
local TeleportService = game:GetService("TeleportService")
local LP = Players.LocalPlayer

-- ==================================================================
-- КНОПКА
-- ==================================================================
local gui = Instance.new("ScreenGui")
gui.Name = "MegaDumper"
gui.Parent = LP:WaitForChild("PlayerGui")

local btn = Instance.new("TextButton")
btn.Name = "DumpBtn"
btn.Text = "📋 КОПИРОВАТЬ ВСЕ ДАННЫЕ"
btn.Size = UDim2.new(0, 320, 0, 60)
btn.Position = UDim2.new(1, -330, 0, 10)
btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
btn.TextColor3 = Color3.fromRGB(0,255,255)
btn.BorderSizePixel = 2
btn.BorderColor3 = Color3.fromRGB(0,255,255)
btn.Font = Enum.Font.GothamBold
btn.TextSize = 13
btn.BackgroundTransparency = 0.5
btn.Parent = gui

local statusTxt = Instance.new("TextLabel")
statusTxt.Name = "Status"
statusTxt.Text = "⚡ ГОТОВ. НАЖМИ КНОПКУ"
statusTxt.Size = UDim2.new(0, 320, 0, 30)
statusTxt.Position = UDim2.new(1, -330, 0, 75)
statusTxt.BackgroundTransparency = 1
statusTxt.TextColor3 = Color3.fromRGB(200,200,200)
statusTxt.Font = Enum.Font.Gotham
statusTxt.TextSize = 11
statusTxt.Parent = gui

local function setStatus(text)
    statusTxt.Text = text
    task.wait()
end

local lines = {}

local function add(t)
    lines[#lines+1] = t
end

local function addSection(title)
    add("")
    add(string.rep("=", 70))
    add(title)
    add(string.rep("=", 70))
end

-- ==================================================================
-- 1. ІНФОРМАЦІЯ ПРО ГРУ
-- ==================================================================
setStatus("📊 1/25 - Інформація про гру...")
addSection("🔥 NFT BATTLE - ULTIMATE MEGA DUMP v5.0")
add("Дата: " .. os.date("%Y-%m-%d %H:%M:%S"))
add("Гравець: " .. LP.Name)
add("DisplayName: " .. LP.DisplayName)
add("UserID: " .. LP.UserId)
add("AccountAge: " .. LP.AccountAge .. " днів")
add("PlaceID: " .. game.PlaceId)
add("GameID: " .. game.GameId)
add("JobID: " .. game.JobId)

-- ==================================================================
-- 2. ВСІ СЕРВІСИ (SERVICES)
