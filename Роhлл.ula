local timers = {"_DayT", "_WeekT", "_WT", "_DT", "_Daily", "_ChristmasTimer", "_HalloweenTimer"}
for _, name in ipairs(timers) do
    local v = LP:FindFirstChild(name)
    if v then 
        local left = v.Value - os.time()
        add(name .. ": " .. v.Value .. " (до скидання: " .. math.floor(left/3600) .. " год)")
    end
end

