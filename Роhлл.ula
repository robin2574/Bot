    "Players", "ReplicatedStorage", "ServerStorage", "Lighting", "SoundService",
    "HttpService", "TweenService", "UserInputService", "RunService", "MarketplaceService",
    "StarterGui", "StarterPlayer", "TeleportService", "Workspace", "Debris",
    "CollectionService", "ContextMenuService", "FriendService", "GroupService",
    "GuiService", "InsertService", "LogService", "MaterialService", "PathfindingService",
