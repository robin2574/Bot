    local amountLabel = Instance.new("TextLabel")
    amountLabel.Parent = amountFrame
    amountLabel.Size = UDim2.new(0.5, -10, 1, 0)
    amountLabel.Position = UDim2.new(0, 5, 0, 0)
    amountLabel.Text = "📦 Кейсов: " .. BattleCaseAmount
    amountLabel.TextColor3 = Color3.fromRGB(150, 255, 100)
    amountLabel.BackgroundTransparency = 1
    amountLabel.Font = Enum.Font.GothamBold
    amountLabel.TextSize = 10
    amountLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    local amountPlus = Instance.new("TextButton")
    amountPlus.Parent = amountFrame
    amountPlus.Size = UDim2.new(0, 30, 0, 30)
    amountPlus.Position = UDim2.new(0.85, 0, 0.5, -15)
    amountPlus.Text = "+"
    amountPlus.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    amountPlus.TextColor3 = Color3.fromRGB(255, 255, 255)
    amountPlus.Font = Enum.Font.GothamBold
    amountPlus.TextSize = 16
    Instance.new("UICorner", amountPlus).CornerRadius = UDim.new(0, 6)
    
    local amountMinus = Instance.new("TextButton")
    amountMinus.Parent = amountFrame
    amountMinus.Size = UDim2.new(0, 30, 0, 30)
    amountMinus.Position = UDim2.new(0.75, -35, 0.5, -15)
    amountMinus.Text = "-"
    amountMinus.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
    amountMinus.TextColor3 = Color3.fromRGB(255, 255, 255)
    amountMinus.Font = Enum.Font.GothamBold
    amountMinus.TextSize = 16
    Instance.new("UICorner", amountMinus).CornerRadius = UDim.new(0, 6)
    
    amountPlus.MouseButton1Click:Connect(function()
        if BattleCaseAmount < 10 then BattleCaseAmount = BattleCaseAmount + 1 end
        amountLabel.Text = "📦 Кейсов: " .. BattleCaseAmount
    end)
    
    amountMinus.MouseButton1Click:Connect(function()
        if BattleCaseAmount > 1 then BattleCaseAmount = BattleCaseAmount - 1 end
        amountLabel.Text = "📦 Кейсов: " .. BattleCaseAmount
    end)
    
    -- Задержка
    local delayFrame = Instance.new("Frame")
    delayFrame.Parent = BattlesPanel
    delayFrame.Size = UDim2.new(1, -10, 0, 45)
    delayFrame.BackgroundColor3 = Color3.fromRGB(35, 40, 25)
    delayFrame.BackgroundTransparency = 0.5
    Instance.new("UICorner", delayFrame).CornerRadius = UDim.new(0, 6)
    
    local delayLabel = Instance.new("TextLabel")
    delayLabel.Parent = delayFrame
    delayLabel.Size = UDim2.new(0.5, -10, 1, 0)
    delayLabel.Position = UDim2.new(0, 5, 0, 0)
    delayLabel.Text = "⏱ Задержка: " .. BattleDelay .. "с"
    delayLabel.TextColor3 = Color3.fromRGB(150, 255, 100)
    delayLabel.BackgroundTransparency = 1
    delayLabel.Font = Enum.Font.GothamBold
    delayLabel.TextSize = 10
    delayLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    local delayBox = Instance.new("TextBox")
    delayBox.Parent = delayFrame
    delayBox.Size = UDim2.new(0, 60, 0, 30)
    delayBox.Position = UDim2.new(0.75, 0, 0.5, -15)
    delayBox.Text = tostring(BattleDelay)
    delayBox.BackgroundColor3 = Color3.fromRGB(30, 35, 30)
    delayBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    delayBox.Font = Enum.Font.GothamBold
    delayBox.TextSize = 12
    Instance.new("UICorner", delayBox).CornerRadius = UDim.new(0, 6)
    
    delayBox.FocusLost:Connect(function()
        local num = tonumber(delayBox.Text)
        if num and num > 0 then BattleDelay = num end
        delayLabel.Text = "⏱ Задержка: " .. BattleDelay .. "с"
        delayBox.Text = tostring(BattleDelay)
    end)
    
    -- Список кейсов
    for _, caseName in pairs(BattleCasesList) do
        local isSelected = (BattleSelectedCase == caseName)
        local btn = Instance.new("TextButton")
        btn.Parent = BattlesPanel
        btn.Size = UDim2.new(1, -10, 0, 28)
        btn.BackgroundColor3 = isSelected and Color3.fromRGB(100, 200, 50) or Color3.fromRGB(35, 40, 25)
        btn.Text = "  " .. caseName
        btn.TextColor3 = isSelected and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 10
        btn.TextXAlignment = Enum.TextXAlignment.Left
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
        
        btn.MouseButton1Click:Connect(function()
            BattleSelectedCase = caseName
            RefreshBattlesList()
            StatusLabel.Text = "⚔️ Кейс: " .. caseName
        end)
    end
    
    local totalHeight = 45 + 45 + (#BattleCasesList * 32)
    BattlesPanel.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
end

-- ========== ПЕРЕКЛЮЧЕНИЕ ВКЛАДОК ==========
CasesTab.MouseButton1Click:Connect(function()
    CasesPanel.Visible = true
    BattlesPanel.Visible = false
    InfoPanel.Visible = false
    CasesTab.BackgroundColor3 = Color3.fromRGB(30, 40, 30)
    CasesTab.TextColor3 = Color3.fromRGB(0, 255, 100)
    BattlesTab.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    BattlesTab.TextColor3 = Color3.fromRGB(200, 200, 200)
    InfoTab.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    InfoTab.TextColor3 = Color3.fromRGB(200, 200, 200)
end)

BattlesTab.MouseButton1Click:Connect(function()
    CasesPanel.Visible = false
    BattlesPanel.Visible = true
    InfoPanel.Visible = false
    BattlesTab.BackgroundColor3 = Color3.fromRGB(30, 40, 30)
    BattlesTab.TextColor3 = Color3.fromRGB(0, 255, 100)
    CasesTab.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    CasesTab.TextColor3 = Color3.fromRGB(200, 200, 200)
    InfoTab.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    InfoTab.TextColor3 = Color3.fromRGB(200, 200, 200)
    RefreshBattlesList()
end)

InfoTab.MouseButton1Click:Connect(function()
    CasesPanel.Visible = false
    BattlesPanel.Visible = false
    InfoPanel.Visible = true
    InfoTab.BackgroundColor3 = Color3.fromRGB(30, 40, 30)
    InfoTab.TextColor3 = Color3.fromRGB(0, 255, 100)
    CasesTab.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    CasesTab.TextColor3 = Color3.fromRGB(200, 200, 200)
    BattlesTab.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    BattlesTab.TextColor3 = Color3.fromRGB(200, 200, 200)
end)

-- ========== КНОПКИ ==========
FarmBtn.MouseButton1Click:Connect(function()
    if #SelectedCases == 0 then
        StatusLabel.Text = "❌ ВЫБЕРИТЕ КЕЙСЫ"
        return
    end
    Farming = not Farming
    if Farming then
        FarmBtn.Text = "⏹ СТОП"
        FarmBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 50)
        StatusLabel.Text = "📦 ФАРМ АКТИВЕН"
        task.spawn(FarmLoop)
    else
        FarmBtn.Text = "▶ ФАРМ"
        FarmBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        StatusLabel.Text = "⚡ СТОП"
    end
end)

SellBtn.MouseButton1Click:Connect(function()
    AutoSellEnabled = not AutoSellEnabled
    if AutoSellEnabled then
        SellBtn.Text = "🟢 ПРОД"
        SellBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        StatusLabel.Text = "💰 ПРОДАЖА ВКЛ"
    else
        SellBtn.Text = "🔴 ПРОД"
        SellBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
        StatusLabel.Text = "💰 ПРОДАЖА ВЫКЛ"
    end
end)

BattleToggleBtn.MouseButton1Click:Connect(function()
    AutoBattle = not AutoBattle
    if AutoBattle then
        BattleToggleBtn.Text = "⏹ БАТЛ"
        BattleToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 50)
        StatusLabel.Text = "⚔️ БАТЛ АКТИВЕН"
        task.spawn(AutoBattleLoop)
    else
        BattleToggleBtn.Text = "⚔️ БАТЛ"
        BattleToggleBtn.BackgroundColor3 = Color3.fromRGB(100, 50, 150)
        StatusLabel.Text = "⚡ СТОП"
    end
end)

LuckToggleBtn.MouseButton1Click:Connect(function()
    LuckActive = not LuckActive
    if LuckActive then
        LuckEndTime = os.time() + 3600
        LuckIcon.Visible = true
        LuckToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        LuckToggleBtn.Text = "🍀 УДАЧА ✓"
        StatusLabel.Text = "🍀 УДАЧА АКТИВНА (1 час)"
    else
        LuckIcon.Visible = false
        LuckToggleBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 150)
        LuckToggleBtn.Text = "🍀 УДАЧА"
        StatusLabel.Text = "🍀 УДАЧА ВЫКЛ"
    end
end)

-- Настройки
SettingsBtn.MouseButton1Click:Connect(function()
    local dialog = Instance.new("Frame")
    dialog.Parent = ScreenGui
    dialog.Size = UDim2.new(0, 300, 0, 150)
    dialog.Position = UDim2.new(0.5, -150, 0.5, -75)
    dialog.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    dialog.BackgroundTransparency = 0.1
    Instance.new("UICorner", dialog).CornerRadius = UDim.new(0, 12)
    
    local closeBtn = Instance.new("TextButton")
    closeBtn.Parent = dialog
    closeBtn.Size = UDim2.new(0, 30, 0, 30)
    closeBtn.Position = UDim2.new(1, -35, 0, 5)
    closeBtn.Text = "✕"
    closeBtn.BackgroundTransparency = 1
    closeBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 16
    
    local amountLabel = Instance.new("TextLabel")
    amountLabel.Parent = dialog
    amountLabel.Size = UDim2.new(0.8, 0, 0, 30)
    amountLabel.Position = UDim2.new(0.1, 0, 0.2, 0)
    amountLabel.Text = "Кейсов за раз: " .. OpenAmount
    amountLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
    amountLabel.BackgroundTransparency = 1
    amountLabel.Font = Enum.Font.GothamBold
    amountLabel.TextSize = 12
    
    local amountSlider = Instance.new("TextBox")
    amountSlider.Parent = dialog
    amountSlider.Size = UDim2.new(0.6, 0, 0, 30)
    amountSlider.Position = UDim2.new(0.2, 0, 0.4, 0)
    amountSlider.Text = tostring(OpenAmount)
    amountSlider.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    amountSlider.TextColor3 = Color3.fromRGB(255, 255, 255)
    amountSlider.Font = Enum.Font.GothamBold
    amountSlider.TextSize = 14
    Instance.new("UICorner", amountSlider).CornerRadius = UDim.new(0, 6)
    
    amountSlider.FocusLost:Connect(function()
        local num = tonumber(amountSlider.Text)
        if num and num >= 1 and num <= 10 then
            OpenAmount = num
            amountLabel.Text = "Кейсов за раз: " .. OpenAmount
            RefreshCasesList()
        end
        amountSlider.Text = tostring(OpenAmount)
    end)
    
    local saveBtn = Instance.new("TextButton")
    saveBtn.Parent = dialog
    saveBtn.Size = UDim2.new(0.6, 0, 0, 35)
    saveBtn.Position = UDim2.new(0.2, 0, 0.65, 0)
    saveBtn.Text = "СОХРАНИТЬ"
    saveBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    saveBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    saveBtn.Font = Enum.Font.GothamBold
    saveBtn.TextSize = 12
    Instance.new("UICorner", saveBtn).CornerRadius = UDim.new(0, 8)
    
    saveBtn.MouseButton1Click:Connect(function()
        dialog:Destroy()
        StatusLabel.Text = "⚙ НАСТРОЙКИ СОХРАНЕНЫ"
    end)
    
    closeBtn.MouseButton1Click:Connect(function()
        dialog:Destroy()
    end)
end)

-- ========== ЗАПУСК ==========
RefreshCasesList()
RefreshBattlesList()

