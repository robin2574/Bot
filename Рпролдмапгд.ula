print("👤 СОЗДАТЕЛЬ: " .. CreatorName)
print("📦 КЕЙСЫ: " .. #CasesDatabase)
print("⚔️ БАТЛЫ: ГОТОВЫ")
print("🍀 УДАЧА: ИКОНКА В ПРАВОМ НИЖНЕМ УГЛУ")
