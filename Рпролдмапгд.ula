local function AddFunctionItem(text, yPos)
    local item = Instance.new("TextLabel")
    item.Parent = InfoPanel
    item.Size = UDim2.new(1, -20, 0, 20)
    item.Position = UDim2.new(0, 10, 0, yPos)
    item.Text = text
    item.TextColor3 = Color3.fromRGB(200, 200, 200)
    item.BackgroundTransparency = 1
    item.Font = Enum.Font.Gotham
    item.TextSize = 10
    item.TextXAlignment = Enum.TextXAlignment.Left
    return item
end

local function BuildInfoPanel()
    AddFunctionItem("📋 СПИСОК ФУНКЦИЙ:", 115)
    for i, func in ipairs(FunctionsList) do
        AddFunctionItem("• " .. func, 140 + (i-1) * 22)
    end
    
    local creditsY = 140 + #FunctionsList * 22 + 10
    local credits = Instance.new("TextLabel")
    credits.Parent = InfoPanel
    credits.Size = UDim2.new(1, -20, 0, 40)
    credits.Position = UDim2.new(0, 10, 0, creditsY)
    credits.Text = "💀 ДРОЧИЛЬНЯ ROBINA\nСоздатель: " .. CreatorName
    credits.TextColor3 = Color3.fromRGB(100, 100, 100)
    credits.BackgroundTransparency = 1
    credits.Font = Enum.Font.Gotham
    credits.TextSize = 9
    credits.TextXAlignment = Enum.TextXAlignment.Center
    
    InfoPanel.CanvasSize = UDim2.new(0, 0, 0, creditsY + 60)
end

BuildInfoPanel()

