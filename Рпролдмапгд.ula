local function CreateLuckIcon()
    local luckIcon = Instance.new("ImageLabel")
    luckIcon.Name = "LuckIcon"
    luckIcon.Size = UDim2.new(0, 38, 0, 38)
    luckIcon.Position = UDim2.new(1, -45, 1, -45)
    luckIcon.BackgroundTransparency = 1
    luckIcon.Visible = false
    luckIcon.Parent = LocalPlayer:WaitForChild("PlayerGui")
    
    -- Создаем иконку через CanvasGroup
    local container = Instance.new("CanvasGroup")
    container.Size = UDim2.new(1, 0, 1, 0)
    container.BackgroundTransparency = 1
    container.Parent = luckIcon
    
    -- Фиолетовый круг с градиентом
    local circle = Instance.new("ImageLabel")
    circle.Size = UDim2.new(0, 32, 0, 32)
    circle.Position = UDim2.new(0.5, -16, 0.5, -16)
    circle.BackgroundTransparency = 1
    circle.Image = "rbxassetid://2666393229"
    circle.ImageColor3 = Color3.fromRGB(168, 85, 247)
    circle.Parent = container
    
    -- Бутылочка
    local bottle = Instance.new("ImageLabel")
    bottle.Size = UDim2.new(0, 12, 0, 20)
    bottle.Position = UDim2.new(0.5, -6, 0.5, -8)
    bottle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    bottle.BackgroundTransparency = 0
    bottle.BorderSizePixel = 0
    bottle.Parent = container
    
    -- Пробка
    local cap = Instance.new("ImageLabel")
    cap.Size = UDim2.new(0, 6, 0, 4)
    cap.Position = UDim2.new(0.5, -3, 0.5, -12)
    cap.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    cap.BackgroundTransparency = 0
    cap.BorderSizePixel = 0
    cap.Parent = container
    
    -- Искры
    local spark1 = Instance.new("ImageLabel")
    spark1.Size = UDim2.new(0, 3, 0, 3)
    spark1.Position = UDim2.new(0.65, 0, 0.2, 0)
    spark1.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    spark1.BackgroundTransparency = 0
    spark1.Parent = container
    
    local spark2 = Instance.new("ImageLabel")
    spark2.Size = UDim2.new(0, 3, 0, 3)
    spark2.Position = UDim2.new(0.65, 0, 0.7, 0)
    spark2.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    spark2.BackgroundTransparency = 0
    spark2.Parent = container
    
    -- Время сверху
    local timeText = Instance.new("TextLabel")
    timeText.Size = UDim2.new(1, 0, 0, 12)
    timeText.Position = UDim2.new(0, 0, 0, -14)
    timeText.Text = ""
    timeText.TextColor3 = Color3.fromRGB(255, 255, 255)
    timeText.BackgroundTransparency = 1
    timeText.Font = Enum.Font.GothamBold
    timeText.TextSize = 11
    timeText.TextScaled = false
    timeText.Parent = luckIcon
    
    -- Обновление времени
    task.spawn(function()
        while luckIcon and luckIcon.Parent do
            if luckIcon.Visible then
                local remaining = math.max(0, LuckEndTime - os.time())
                local minutes = math.floor(remaining / 60)
                local seconds = remaining % 60
                timeText.Text = string.format("%02d:%02d", minutes, seconds)
            end
            task.wait(1)
        end
    end)
    
    return luckIcon
end

local LuckIcon = CreateLuckIcon()

-- ========== ФУНКЦИИ ==========
local function formatPrice(value, mult)
    local total = value * (mult or 1)
    if total == 0 then return "FREE" end
    local str = tostring(math.floor(total))
    local result = ""
    for i = #str, 1, -1 do
        if (#str - i) % 3 == 0 and i ~= #str then result = "," .. result end
        result = str:sub(i, i) .. result
    end
    return result
end

local function Click(x, y)
    pcall(function()
        vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.05)
        vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end)
end

local function SelectBattleCase(caseName)
    local y = Coords.Cases[caseName:gsub(" ", "_"):gsub("'", "")]
    if y then Click(540, y); return true end
    return false
end

local function CreateBattle()
    pcall(function()
        Click(Coords.BattlesBtn[1], Coords.BattlesBtn[2]); task.wait(1)
        Click(Coords.CreateBattle[1], Coords.CreateBattle[2]); task.wait(1)
        for i = 1, BattleCaseAmount do
            Click(Coords.AddCase[1], Coords.AddCase[2]); task.wait(0.5)
            Click(Coords.CaseSlot[1], Coords.CaseSlot[2]); task.wait(0.3)
        end
        SelectBattleCase(BattleSelectedCase); task.wait(0.5)
        Click(Coords.CreateBtn[1], Coords.CreateBtn[2]); task.wait(1.5)
        Click(Coords.PlayBot[1], Coords.PlayBot[2])
    end)
end

local function AutoBattleLoop()
    while AutoBattle do CreateBattle(); task.wait(BattleDelay) end
end

local function FarmLoop()
    while Farming do
        pcall(function()
            local Events = ReplicatedStorage:FindFirstChild("Events")
            if Events and Events:FindFirstChild("OpenCase") and #SelectedCases > 0 then
                local OpenCase = Events.OpenCase
                for _, caseName in pairs(SelectedCases) do
                    if OpenCase:IsA("RemoteFunction") then
                        OpenCase:InvokeServer(caseName, OpenAmount)
                    else
                        OpenCase:FireServer(caseName, OpenAmount)
                    end
                    task.wait(0.1)
                end
            end
            if AutoSellEnabled and Events and Events:FindFirstChild("Inventory") then
                Events.Inventory:FireServer("Sell", "ALL")
            end
        end)
        task.wait(FarmDelay)
    end
end

