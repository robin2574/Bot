local function RefreshBattlesList()
    for _, child in pairs(BattlesPanel:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("Frame") then child:Destroy() end
    end
    
    -- Количество кейсов
    local amountFrame = Instance.new("Frame")
    amountFrame.Parent = BattlesPanel
    amountFrame.Size = UDim2.new(1, -10, 0, 45)
