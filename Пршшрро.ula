local function RefreshBattlesList()
    for _, child in pairs(BattlesPanel:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    -- Настройка количества кейсов
    local amountFrame = Instance.new("Frame")
    amountFrame.Parent = BattlesPanel
    amountFrame.Size = UDim2.new(1, -10, 0, 45)
    amountFrame.BackgroundColor3 = Color3.fromRGB(35, 40, 25)
    amountFrame.BackgroundTransparency = 0.5
    Instance.new("UICorner", amountFrame).CornerRadius = UDim.new(0, 6)
    
    local amountLabel = Instance.new("TextLabel")
    amountLabel.Parent = amountFrame
    amountLabel.Size = UDim2.new(0.5, -10, 1, 0)
    amountLabel.Position = UDim2.new(0, 5, 0, 0)
    amountLabel.Text = "📦 Кейсов в битве: " .. BattleCaseAmount
    amountLabel.TextColor3 = Color3.fromRGB(150, 255, 100)
    amountLabel.BackgroundTransparency = 1
    amountLabel.Font = Enum.Font.GothamBold
    amountLabel.TextSize = 10
    amountLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    local amountPlus = Instance.new("TextButton")
    amountPlus.Parent = amountFrame
    amountPlus.Size = UDim2.new(0, 30, 0, 30)
    amountPlus.Position = UDim2.new(0.85, 0, 0.5, -15)
    amountPlus.Text = "+"
    amountPlus.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    amountPlus.TextColor3 = Color3.fromRGB(255, 255, 255)
    amountPlus.Font = Enum.Font.GothamBold
    amountPlus.TextSize = 16
    Instance.new("UICorner", amountPlus).CornerRadius = UDim.new(0, 6)
    
    local amountMinus = Instance.new("TextButton")
    amountMinus.Parent = amountFrame
    amountMinus.Size = UDim2.new(0, 30, 0, 30)
    amountMinus.Position = UDim2.new(0.75, -35, 0.5, -15)
    amountMinus.Text = "-"
    amountMinus.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
    amountMinus.TextColor3 = Color3.fromRGB(255, 255, 255)
    amountMinus.Font = Enum.Font.GothamBold
    amountMinus.TextSize = 16
    Instance.new("UICorner", amountMinus).CornerRadius = UDim.new(0, 6)
    
    amountPlus.MouseButton1Click:Connect(function()
        if BattleCaseAmount < 10 then BattleCaseAmount = BattleCaseAmount + 1 end
        amountLabel.Text = "📦 Кейсов в битве: " .. BattleCaseAmount
    end)
    
    amountMinus.MouseButton1Click:Connect(function()
        if BattleCaseAmount > 1 then BattleCaseAmount = BattleCaseAmount - 1 end
        amountLabel.Text = "📦 Кейсов в битве: " .. BattleCaseAmount
    end)
    
    -- Задержка между битвами
    local delayFrame = Instance.new("Frame")
    delayFrame.Parent = BattlesPanel
    delayFrame.Size = UDim2.new(1, -10, 0, 45)
    delayFrame.BackgroundColor3 = Color3.fromRGB(35, 40, 25)
    delayFrame.BackgroundTransparency = 0.5
    Instance.new("UICorner", delayFrame).CornerRadius = UDim.new(0, 6)
    
    local delayLabel = Instance.new("TextLabel")
    delayLabel.Parent = delayFrame
    delayLabel.Size = UDim2.new(0.5, -10, 1, 0)
    delayLabel.Position = UDim2.new(0, 5, 0, 0)
    delayLabel.Text = "⏱ Задержка: " .. BattleDelay .. " сек"
    delayLabel.TextColor3 = Color3.fromRGB(150, 255, 100)
    delayLabel.BackgroundTransparency = 1
    delayLabel.Font = Enum.Font.GothamBold
    delayLabel.TextSize = 10
    delayLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    local delayBox = Instance.new("TextBox")
    delayBox.Parent = delayFrame
    delayBox.Size = UDim2.new(0, 60, 0, 30)
    delayBox.Position = UDim2.new(0.75, 0, 0.5, -15)
    delayBox.Text = tostring(BattleDelay)
    delayBox.BackgroundColor3 = Color3.fromRGB(30, 35, 30)
    delayBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    delayBox.Font = Enum.Font.GothamBold
    delayBox.TextSize = 12
    Instance.new("UICorner", delayBox).CornerRadius = UDim.new(0, 6)
    
    delayBox.FocusLost:Connect(function()
        local num = tonumber(delayBox.Text)
        if num and num > 0 then BattleDelay = num end
        delayLabel.Text = "⏱ Задержка: " .. BattleDelay .. " сек"
        delayBox.Text = tostring(BattleDelay)
    end)
    
    -- Список кейсов для батла
    for _, caseName in pairs(BattleCasesList) do
        local isSelected = (BattleSelectedCase == caseName)
        local btn = Instance.new("TextButton")
        btn.Parent = BattlesPanel
        btn.Size = UDim2.new(1, -10, 0, 28)
        btn.BackgroundColor3 = isSelected and Color3.fromRGB(100, 200, 50) or Color3.fromRGB(35, 40, 25)
        btn.Text = "  " .. caseName
        btn.TextColor3 = isSelected and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 10
        btn.TextXAlignment = Enum.TextXAlignment.Left
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
        
        btn.MouseButton1Click:Connect(function()
            BattleSelectedCase = caseName
            RefreshBattlesList()
            StatusLabel.Text = "⚔️ Выбран кейс: " .. caseName
        end)
    end
    
    local totalHeight = 45 + 45 + (#BattleCasesList * 32)
    BattlesPanel.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
end

