    BattlesTab.TextColor3 = Color3.fromRGB(0, 255, 100)
    CasesTab.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    CasesTab.TextColor3 = Color3.fromRGB(200, 200, 200)
    RefreshBattlesList()
end)

-- ========== КНОПКИ ==========
FarmBtn.MouseButton1Click:Connect(function()
    if #SelectedCases == 0 then
        StatusLabel.Text = "❌ ВЫБЕРИТЕ КЕЙСЫ"
        return
    end
    Farming = not Farming
    if Farming then
        FarmBtn.Text = "⏹ СТОП"
        FarmBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 50)
        StatusLabel.Text = "📦 ФАРМ АКТИВЕН"
        task.spawn(FarmLoop)
    else
        FarmBtn.Text = "▶ ФАРМ"
        FarmBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        StatusLabel.Text = "⚡ СТОП"
    end
end)

SellBtn.MouseButton1Click:Connect(function()
    AutoSellEnabled = not AutoSellEnabled
    if AutoSellEnabled then
        SellBtn.Text = "🟢 ПРОД"
        SellBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        StatusLabel.Text = "💰 АВТО-ПРОДАЖА ВКЛ"
    else
        SellBtn.Text = "🔴 ПРОД"
        SellBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
        StatusLabel.Text = "💰 АВТО-ПРОДАЖА ВЫКЛ"
    end
end)

BattleToggleBtn.MouseButton1Click:Connect(function()
    AutoBattle = not AutoBattle
    if AutoBattle then
        BattleToggleBtn.Text = "⏹ БАТЛ"
        BattleToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 50)
        StatusLabel.Text = "⚔️ БАТЛ АКТИВЕН"
        task.spawn(AutoBattleLoop)
    else
        BattleToggleBtn.Text = "⚔️ БАТЛ"
        BattleToggleBtn.BackgroundColor3 = Color3.fromRGB(100, 50, 150)
        StatusLabel.Text = "⚡ СТОП"
    end
end)

InfoBtn.MouseButton1Click:Connect(function()
    StatusLabel.Text = "ℹ ДРОЧИЛЬНЯ ROBINA | АВТОР: TROTULOV39"
    task.wait(2)
    StatusLabel.Text = AutoBattle and "⚔️ БАТЛ АКТИВЕН" or (Farming and "📦 ФАРМ АКТИВЕН" or "⚡ ГОТОВ")
end)

SettingsBtn.MouseButton1Click:Connect(function()
    StatusLabel.Text = "⚙ НАСТРОЙКИ: Задержка " .. FarmDelay .. "с | Кейсов " .. OpenAmount
end)

