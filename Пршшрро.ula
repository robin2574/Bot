-- ========== ЗАПОЛНЕНИЕ СПИСКА КЕЙСОВ ==========
local function RefreshCasesList()
    for _, child in pairs(CasesPanel:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    for _, data in pairs(CasesDatabase) do
        local isSelected = false
        for _, s in pairs(SelectedCases) do if s == data.Name then isSelected = true break end end
        
        local btn = Instance.new("TextButton")
        btn.Parent = CasesPanel
        btn.Size = UDim2.new(1, -10, 0, 28)
        btn.BackgroundColor3 = isSelected and Color3.fromRGB(100, 200, 50) or Color3.fromRGB(35, 40, 25)
        btn.Text = "  " .. data.Name
        btn.TextColor3 = isSelected and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 10
        btn.TextXAlignment = Enum.TextXAlignment.Left
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
        
        local price = Instance.new("TextLabel")
        price.Parent = btn
        price.Size = UDim2.new(0, 80, 1, 0)
        price.Position = UDim2.new(1, -85, 0, 0)
        price.Text = formatPrice(data.Price, OpenAmount)
        price.TextColor3 = isSelected and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(150, 255, 100)
        price.BackgroundTransparency = 1
        price.Font = Enum.Font.GothamBold
        price.TextSize = 9
        price.TextXAlignment = Enum.TextXAlignment.Right
        
        btn.MouseButton1Click:Connect(function()
            local found = false
            for i, s in pairs(SelectedCases) do
                if s == data.Name then table.remove(SelectedCases, i); found = true; break end
            end
            if not found then table.insert(SelectedCases, data.Name) end
            StatusLabel.Text = "📦 Выбрано: " .. #SelectedCases .. " кейсов"
            RefreshCasesList()
        end)
    end
    CasesPanel.CanvasSize = UDim2.new(0, 0, 0, #CasesDatabase * 32)
end

