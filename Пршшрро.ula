local BattleDelay = 35
local LuckActive = false
local LuckMultiplier = 2
local LuckEndTime = 0
local OpenAmount = 1
local FarmDelay = 0.01

-- ========== ФУНКЦИИ ==========
local function formatPrice(value, mult)
    local total = value * (mult or 1)
    if total == 0 then return "FREE" end
    local str = tostring(math.floor(total))
    local result = ""
    for i = #str, 1, -1 do
        if (#str - i) % 3 == 0 and i ~= #str then result = "," .. result end
        result = str:sub(i, i) .. result
    end
    return result
end

local function Click(x, y)
    pcall(function()
        vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.05)
        vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end)
end

local function SelectBattleCase(caseName)
    local y = Coords.Cases[caseName:gsub(" ", "_"):gsub("'", "")]
    if y then Click(540, y); return true end
    return false
end

local function CreateBattle()
    pcall(function()
        Click(Coords.BattlesBtn[1], Coords.BattlesBtn[2]); task.wait(1)
        Click(Coords.CreateBattle[1], Coords.CreateBattle[2]); task.wait(1)
        for i = 1, BattleCaseAmount do
            Click(Coords.AddCase[1], Coords.AddCase[2]); task.wait(0.5)
            Click(Coords.CaseSlot[1], Coords.CaseSlot[2]); task.wait(0.3)
        end
        SelectBattleCase(BattleSelectedCase); task.wait(0.5)
        Click(Coords.CreateBtn[1], Coords.CreateBtn[2]); task.wait(1.5)
        Click(Coords.PlayBot[1], Coords.PlayBot[2])
    end)
end

local function AutoBattleLoop()
    while AutoBattle do CreateBattle(); task.wait(BattleDelay) end
end

local function FarmLoop()
    while Farming do
        pcall(function()
            local Events = ReplicatedStorage:FindFirstChild("Events")
            if Events and Events:FindFirstChild("OpenCase") and #SelectedCases > 0 then
                local OpenCase = Events.OpenCase
                for _, caseName in pairs(SelectedCases) do
                    if OpenCase:IsA("RemoteFunction") then
                        OpenCase:InvokeServer(caseName, OpenAmount)
                    else
                        OpenCase:FireServer(caseName, OpenAmount)
                    end
                    task.wait(0.1)
                end
            end
            if AutoSellEnabled and Events and Events:FindFirstChild("Inventory") then
                Events.Inventory:FireServer("Sell", "ALL")
            end
        end)
        task.wait(FarmDelay)
    end
end

