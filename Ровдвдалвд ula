-- ========== ИСПРАВЛЕНИЕ: ФАРМ ЛУП ДЛЯ ВЫБРАННЫХ КЕЙСОВ ==========
local function FarmLoop()
    while Farming do
        pcall(function()
            local Events = ReplicatedStorage:FindFirstChild("Events")
            if Events then
                local OpenCase = Events:FindFirstChild("OpenCase")
                if OpenCase and #SelectedCases > 0 then
                    -- Открываем каждый выбранный кейс по очереди
                    for _, caseName in pairs(SelectedCases) do
                        if OpenCase:IsA("RemoteFunction") then
                            OpenCase:InvokeServer(caseName, OpenAmount)
                        else
                            OpenCase:FireServer(caseName, OpenAmount)
                        end
                        task.wait(0.1) -- Небольшая задержка между разными кейсами
                    end
                end
                if AutoSell then
                    local Inventory = Events:FindFirstChild("Inventory")
                    if Inventory then
                        if Inventory:IsA("RemoteFunction") then
                            Inventory:InvokeServer("Sell", "ALL")
                        else
                            Inventory:FireServer("Sell", "ALL")
                        end
                    end
                end
            end
        end)
        task.wait(FarmDelay)
    end
end

