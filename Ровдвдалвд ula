local function formatPrice(value, multiplier)
    local total = value * (multiplier or 1)
    if total == 0 then return "FREE" end
    local str = tostring(math.floor(total))
    local result = ""
    local count = 0
    for i = #str, 1, -1 do
        if count > 0 and count % 3 == 0 then
            result = "," .. result
        end
        result = str:sub(i, i) .. result
        count = count + 1
    end
    return result
end

