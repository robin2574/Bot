ModTitle.BackgroundTransparency = 1
ModTitle.Position = UDim2.new(0, 0, 0, 0)
ModTitle.Size = UDim2.new(1, 0, 0, 20)
ModTitle.Font = Enum.Font.GothamBold
ModTitle.Text = "MOD MENU"
ModTitle.TextColor3 = Color3.fromRGB(255, 100, 100)
ModTitle.TextSize = 10

local CloseMod = Instance.new("TextButton")
CloseMod.Parent = ModFrame
CloseMod.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
CloseMod.Position = UDim2.new(0.85, 0, 0.01, 0)
CloseMod.Size = UDim2.new(0, 20, 0, 20)
CloseMod.Font = Enum.Font.GothamBold
CloseMod.Text = "X"
CloseMod.TextColor3 = Color3.fromRGB(255, 255, 255)
CloseMod.TextSize = 10
Instance.new("UICorner", CloseMod).CornerRadius = UDim.new(0, 3)
CloseMod.MouseButton1Click:Connect(function() ModFrame.Visible = false end)

ModBtn.MouseButton1Click:Connect(function() ModFrame.Visible = true end)

