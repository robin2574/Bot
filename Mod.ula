-- ========== TON BATTLE - FULL MOD MENU (PHONE) ==========
local player = game:GetService("Players").LocalPlayer
local Events = game:GetService("ReplicatedStorage"):WaitForChild("Events")
local AbuseVisual = Events:FindFirstChild("AbuseVisual")
local SettingsEvent = Events:FindFirstChild("SettingsEvent")

-- ========== ГОЛОВНЕ МЕНЮ ==========
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "MainMenu"
ScreenGui.Parent = player:WaitForChild("PlayerGui")

local MainFrame = Instance.new("Frame")
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 20, 10)
MainFrame.BorderColor3 = Color3.fromRGB(100, 255, 100)
MainFrame.BorderSizePixel = 1
MainFrame.Position = UDim2.new(0.05, 0, 0.1, 0)
MainFrame.Size = UDim2.new(0, 160, 0, 200)
MainFrame.Active = true
MainFrame.Draggable = true
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)

local Title = Instance.new("TextLabel")
Title.Parent = MainFrame
Title.BackgroundTransparency = 1
Title.Position = UDim2.new(0, 0, 0, 0)
Title.Size = UDim2.new(1, 0, 0, 20)
Title.Font = Enum.Font.GothamBold
Title.Text = "TON BATTLE"
Title.TextColor3 = Color3.fromRGB(100, 255, 100)
Title.TextSize = 10

-- Кнопка MOD MENU
local ModBtn = Instance.new("TextButton")
ModBtn.Parent = MainFrame
ModBtn.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
ModBtn.BorderColor3 = Color3.fromRGB(255, 200, 50)
ModBtn.BorderSizePixel = 1
ModBtn.Position = UDim2.new(0.05, 0, 0.12, 0)
ModBtn.Size = UDim2.new(0.9, 0, 0, 30)
ModBtn.Font = Enum.Font.GothamBold
ModBtn.Text = "MOD MENU"
ModBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ModBtn.TextSize = 12
Instance.new("UICorner", ModBtn).CornerRadius = UDim.new(0, 5)

-- ========== MOD MENU ВІКНО ==========
