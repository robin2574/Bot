BPResetBtn.Text = "Reset BP Claims"
BPResetBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
BPResetBtn.TextSize = 8
Instance.new("UICorner", BPResetBtn).CornerRadius = UDim.new(0, 4)
BPResetBtn.MouseButton1Click:Connect(function()
    local bp = player:FindFirstChild("_BPClaimed")
    if bp then for _, v in ipairs(bp:GetChildren()) do if v:IsA("BoolValue") then v.Value = false end end end
end)

