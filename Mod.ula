y = y + 0.03

-- Кнопка LUCK
local LuckBtn = Instance.new("TextButton")
LuckBtn.Parent = ModFrame
LuckBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 0)
LuckBtn.Position = UDim2.new(0.05, 0, y, 0)
LuckBtn.Size = UDim2.new(0.43, 0, 0, 25)
LuckBtn.Font = Enum.Font.GothamBold
LuckBtn.Text = "LUCK x6"
LuckBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
LuckBtn.TextSize = 9
Instance.new("UICorner", LuckBtn).CornerRadius = UDim.new(0, 4)
LuckBtn.MouseButton1Click:Connect(function()
    for _, e in ipairs({AbuseVisual, SettingsEvent}) do
        if e then
            e:FireServer("Lucky", 6)
            e:FireServer("Lucky", "x6")
            e:FireServer("x6")
        end
    end
end)

-- Кнопка BLESS
local BlessBtn = Instance.new("TextButton")
BlessBtn.Parent = ModFrame
BlessBtn.BackgroundColor3 = Color3.fromRGB(150, 100, 255)
