ModFrame.BorderColor3 = Color3.fromRGB(255, 100, 100)
ModFrame.BorderSizePixel = 2
ModFrame.Position = UDim2.new(0.5, 0, 0.05, 0)
ModFrame.Size = UDim2.new(0, 170, 0, 280)
ModFrame.Active = true
ModFrame.Draggable = true
ModFrame.Visible = false
Instance.new("UICorner", ModFrame).CornerRadius = UDim.new(0, 8)

local ModTitle = Instance.new("TextLabel")
