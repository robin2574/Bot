BlessBtn.TextSize = 9
Instance.new("UICorner", BlessBtn).CornerRadius = UDim.new(0, 4)
BlessBtn.MouseButton1Click:Connect(function()
    for _, e in ipairs({AbuseVisual, SettingsEvent}) do
        if e then
            e:FireServer("Server", "Blessing")
            e:FireServer("ServerBlessing")
            e:FireServer("Blessing", "All")
        end
    end
end)

