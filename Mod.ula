y = y + 0.09

-- Index (12)
local IndexName = Instance.new("TextBox")
IndexName.Parent = ModFrame
IndexName.BackgroundColor3 = Color3.fromRGB(30, 35, 20)
IndexName.Position = UDim2.new(0.05, 0, y, 0)
IndexName.Size = UDim2.new(0.55, 0, 0, 20)
IndexName.Font = Enum.Font.Gotham
IndexName.PlaceholderText = "NFT Name"
IndexName.Text = ""
IndexName.TextColor3 = Color3.fromRGB(255, 255, 255)
IndexName.TextSize = 6
Instance.new("UICorner", IndexName).CornerRadius = UDim.new(0, 3)

local IndexCount = Instance.new("TextBox")
IndexCount.Parent = ModFrame
IndexCount.BackgroundColor3 = Color3.fromRGB(30, 35, 20)
IndexCount.Position = UDim2.new(0.05, 0, y + 0.07, 0)
IndexCount.Size = UDim2.new(0.3, 0, 0, 20)
IndexCount.Font = Enum.Font.Gotham
IndexCount.PlaceholderText = "Count"
IndexCount.Text = ""
IndexCount.TextColor3 = Color3.fromRGB(255, 255, 255)
IndexCount.TextSize = 6
Instance.new("UICorner", IndexCount).CornerRadius = UDim.new(0, 3)

local IndexBtn = Instance.new("TextButton")
IndexBtn.Parent = ModFrame
IndexBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 50)
IndexBtn.Position = UDim2.new(0.4, 0, y + 0.07, 0)
IndexBtn.Size = UDim2.new(0.55, 0, 0, 20)
IndexBtn.Font = Enum.Font.Gotham
IndexBtn.Text = "ADD INDEX"
IndexBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
IndexBtn.TextSize = 7
Instance.new("UICorner", IndexBtn).CornerRadius = UDim.new(0, 3)
IndexBtn.MouseButton1Click:Connect(function()
    local name = IndexName.Text
    local count = IndexCount.Text
    if name ~= "" and count ~= "" then
        local idx = player:FindFirstChild("_Index") or Instance.new("Folder", player)
        idx.Name = "_Index"
        local item = idx:FindFirstChild(name) or Instance.new("StringValue", idx)
        item.Name = name
        item.Value = count
    end
end)

y = y + 0.16

