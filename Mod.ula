local InvBtn = Instance.new("TextButton")
InvBtn.Parent = ModFrame
InvBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 50)
InvBtn.Position = UDim2.new(0.63, 0, y, 0)
InvBtn.Size = UDim2.new(0.32, 0, 0, 20)
InvBtn.Font = Enum.Font.Gotham
InvBtn.Text = "ADD INV"
InvBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
InvBtn.TextSize = 7
Instance.new("UICorner", InvBtn).CornerRadius = UDim.new(0, 3)
InvBtn.MouseButton1Click:Connect(function()
    local name = InvBox.Text
    if name ~= "" then
        local inv = player:FindFirstChild("_Inventory") or Instance.new("Folder", player)
        inv.Name = "_Inventory"
        local item = Instance.new("StringValue", inv)
        item.Name = name
        item.Value = name
    end
end)

print("MOD MENU LOADED!")
