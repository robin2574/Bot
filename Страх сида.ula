    ["Luxury"] = 119999, ["Glitch"] = 135000, ["G63"] = 177777,
    ["Dream"] = 250000, ["Porsche 911"] = 599999, ["URUS"] = 1666666,
    ["Bloody Night"] = 5000000, ["Marina"] = 12999999, ["Abyss Core"] = 33000000,
    ["Cursed Demon"] = 36666666, ["Heavenfall"] = 64000000, ["Photon Core"] = 43333,
