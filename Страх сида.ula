local function startLucky(multiplier)
    LuckyMultiplier = multipler
    LuckyActive = true
    LuckyTime = 30 * 60 -- 30 минут в секундах
    
    -- Активируем через SettingsEvent или AbuseVisual
    pcall(function()
        local SettingsEvent = Events:FindFirstChild("SettingsEvent")
        if SettingsEvent then
            SettingsEvent:FireServer("Lucky", multipler)
        end
    end)
    pcall(function()
        local AbuseVisual = Events:FindFirstChild("AbuseVisual")
        if AbuseVisual then
            AbuseVisual:FireServer("Lucky", multipler)
        end
    end)
    
    -- Обновляем таймер
    task.spawn(function()
        while LuckyActive and LuckyTime > 0 do
            LuckyTime = LuckyTime - 1
            task.wait(1)
        end
        LuckyActive = false
    end)
end

Lucky2Btn.MouseButton1Click:Connect(function() startLucky(2) end)
Lucky4Btn.MouseButton1Click:Connect(function() startLucky(4) end)
Lucky6Btn.MouseButton1Click:Connect(function() startLucky(6) end)

